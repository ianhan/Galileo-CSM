 BOOLEAN             IsHaveMediaInFloppy = TRUE;
 
+STATIC
+BOOLEAN
+LegacyBiosDevicePathIsUsb (
+  IN EFI_DEVICE_PATH_PROTOCOL  *DevicePath
+  )
+{
+  while (!IsDevicePathEnd (DevicePath)) {
+    if ((DevicePathType (DevicePath) == MESSAGING_DEVICE_PATH) &&
+        (DevicePathSubType (DevicePath) == MSG_USB_DP)) {
+      return TRUE;
+    }
+
+    DevicePath = NextDevicePathNode (DevicePath);
+  }
+
+  return FALSE;
+}
+
+STATIC
+UINT8
+LegacyBiosUsbDevicePathLun (
+  IN EFI_DEVICE_PATH_PROTOCOL  *DevicePath
+  )
+{
+  while (!IsDevicePathEnd (DevicePath)) {
+    if ((DevicePathType (DevicePath) == MESSAGING_DEVICE_PATH) &&
+        (DevicePathSubType (DevicePath) == MSG_DEVICE_LOGICAL_UNIT_DP)) {
+      return ((DEVICE_LOGICAL_UNIT_DEVICE_PATH *) DevicePath)->Lun;
+    }
+
+    DevicePath = NextDevicePathNode (DevicePath);
+  }
+
+  return 0;
+}
+
+STATIC
+EFI_STATUS
+LegacyBiosGetPciLocationFromDevicePath (
+  IN  EFI_DEVICE_PATH_PROTOCOL  *DevicePath,
+  OUT UINTN                     *Segment,
+  OUT UINTN                     *Bus,
+  OUT UINTN                     *Device,
+  OUT UINTN                     *Function
+  )
+{
+  EFI_STATUS                Status;
+  EFI_HANDLE                PciHandle;
+  EFI_PCI_IO_PROTOCOL       *PciIo;
+  EFI_DEVICE_PATH_PROTOCOL  *PciDevicePath;
+  EFI_DEVICE_PATH_PROTOCOL  *RemainingDevicePath;
+
+  PciDevicePath = DuplicateDevicePath (DevicePath);
+  if (PciDevicePath == NULL) {
+    return EFI_OUT_OF_RESOURCES;
+  }
+
+  RemainingDevicePath = PciDevicePath;
+  Status = gBS->LocateDevicePath (
+                  &gEfiPciIoProtocolGuid,
+                  &RemainingDevicePath,
+                  &PciHandle
+                  );
+  if (!EFI_ERROR (Status)) {
+    Status = gBS->HandleProtocol (
+                    PciHandle,
+                    &gEfiPciIoProtocolGuid,
+                    (VOID **) &PciIo
+                    );
+  }
+
+  if (!EFI_ERROR (Status)) {
+    Status = PciIo->GetLocation (PciIo, Segment, Bus, Device, Function);
+  }
+
+  FreePool (PciDevicePath);
+  return Status;
+}
+
+STATIC
+VOID
+LegacyBiosAppendUsbMassStorageBbsEntries (
+  IN LEGACY_BIOS_INSTANCE  *Private
+  )
+{
+  EFI_STATUS                Status;
+  UINTN                     HandleCount;
+  EFI_HANDLE                *HandleBuffer;
+  UINTN                     HandleIndex;
+  EFI_BLOCK_IO_PROTOCOL     *BlockIo;
+  EFI_DEVICE_PATH_PROTOCOL  *DevicePath;
+  EFI_TO_COMPATIBILITY16_BOOT_TABLE *BootTable;
+  BBS_TABLE                 *BbsTable;
+  UINT32                    BbsIndex;
+  UINTN                     Segment;
+  UINTN                     Bus;
+  UINTN                     Device;
+  UINTN                     Function;
+
+  HandleBuffer = NULL;
+  Status = gBS->LocateHandleBuffer (
+                  ByProtocol,
+                  &gEfiBlockIoProtocolGuid,
+                  NULL,
+                  &HandleCount,
+                  &HandleBuffer
+                  );
+  if (EFI_ERROR (Status)) {
+    return;
+  }
+
+  BootTable = &Private->IntThunk->EfiToLegacy16BootTable;
+  BbsTable  = (BBS_TABLE *)(UINTN) BootTable->BbsTable;
+  BbsIndex  = BootTable->NumberBbsEntries;
+
+  for (HandleIndex = 0; HandleIndex < HandleCount; HandleIndex++) {
+    Status = gBS->HandleProtocol (
+                    HandleBuffer[HandleIndex],
+                    &gEfiBlockIoProtocolGuid,
+                    (VOID **) &BlockIo
+                    );
+    if (EFI_ERROR (Status) ||
+        (BlockIo->Media == NULL) ||
+        !BlockIo->Media->MediaPresent ||
+        BlockIo->Media->LogicalPartition) {
+      continue;
+    }
+
+    Status = gBS->HandleProtocol (
+                    HandleBuffer[HandleIndex],
+                    &gEfiDevicePathProtocolGuid,
+                    (VOID **) &DevicePath
+                    );
+    if (EFI_ERROR (Status) || !LegacyBiosDevicePathIsUsb (DevicePath)) {
+      continue;
+    }
+
+    Status = LegacyBiosGetPciLocationFromDevicePath (
+               DevicePath,
+               &Segment,
+               &Bus,
+               &Device,
+               &Function
+               );
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    if (BbsIndex >= MAX_BBS_ENTRIES - 1) {
+      break;
+    }
+
+    ZeroMem (&BbsTable[BbsIndex], sizeof (BBS_TABLE));
+    BbsTable[BbsIndex].BootPriority             = BBS_UNPRIORITIZED_ENTRY;
+    BbsTable[BbsIndex].Bus                      = (UINT32) Bus;
+    BbsTable[BbsIndex].Device                   = (UINT32) Device;
+    BbsTable[BbsIndex].Function                 = (UINT32) Function;
+    BbsTable[BbsIndex].Class                    = PCI_CLASS_SERIAL;
+    BbsTable[BbsIndex].SubClass                 = PCI_CLASS_SERIAL_USB;
+    BbsTable[BbsIndex].DeviceType               = BBS_HARDDISK;
+    BbsTable[BbsIndex].StatusFlags.MediaPresent = 2;
+    BbsTable[BbsIndex].AssignedDriveNumber      = 0xff;
+    BbsTable[BbsIndex].IBV1                     = CSM_USB_BBS_SIGNATURE;
+    BbsTable[BbsIndex].IBV2                     = LegacyBiosUsbDevicePathLun (DevicePath);
+
+    DEBUG ((
+      EFI_D_INFO,
+      "LegacyBios: added USB BBS entry %u for %02x/%02x/%02x lun %u\n",
+      (UINTN) BbsIndex,
+      (UINTN) Bus,
+      (UINTN) Device,
+      (UINTN) Function,
+      (UINTN) BbsTable[BbsIndex].IBV2
+      ));
+
+    BbsIndex++;
+  }
+
+  BootTable->NumberBbsEntries = BbsIndex;
+  if (BbsIndex < MAX_BBS_ENTRIES) {
+    BbsTable[BbsIndex].BootPriority = BBS_IGNORE_ENTRY;
+  }
+
+  if (HandleBuffer != NULL) {
+    FreePool (HandleBuffer);
+  }
+}
