 .../LegacyBootManagerLib/InternalLegacyBm.h        |   1 +
 .../Library/LegacyBootManagerLib/LegacyBm.c        | 186 ++++++++++++---
 .../PlatformBootManagerLib/PlatformBootManager.c   |  26 +++
