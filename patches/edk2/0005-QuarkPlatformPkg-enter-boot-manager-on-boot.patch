@@ -18,10 +18,200 @@ SPDX-License-Identifier: BSD-2-Clause-Patent
 #define FLOPPY_PRESENT_WITH_MEDIA    1
 #define FLOPPY_PRESENT_NO_MEDIA      2
 
+#define CSM_USB_BBS_SIGNATURE  SIGNATURE_32 ('E', 'U', 'S', 'B')
