+STATIC
+UINT32
+LegacyBiosUsbBbsKeyUpdate (
+  IN UINT32  Key,
+  IN UINT8   Data
+  )
+{
+  Key ^= Data;
+  Key *= 16777619;
+
+  return Key;
+}
+
+STATIC
+BOOLEAN
+LegacyBiosUsbDevicePathKey (
+  IN  EFI_DEVICE_PATH_PROTOCOL  *DevicePath,
+  OUT UINT32                    *Key
+  )
+{
+  BOOLEAN                           HaveUsbNode;
+  UINT8                             Lun;
+  USB_DEVICE_PATH                   *Usb;
+  DEVICE_LOGICAL_UNIT_DEVICE_PATH   *LogicalUnit;
+
+  if ((DevicePath == NULL) || (Key == NULL)) {
+    return FALSE;
+  }
+
+  HaveUsbNode = FALSE;
+  Lun         = 0;
+  *Key        = CSM_USB_BBS_KEY_INIT;
+
+  while (!IsDevicePathEnd (DevicePath)) {
+    if (DevicePathType (DevicePath) == MESSAGING_DEVICE_PATH) {
+      switch (DevicePathSubType (DevicePath)) {
+      case MSG_USB_DP:
+        Usb         = (USB_DEVICE_PATH *) DevicePath;
+        *Key        = LegacyBiosUsbBbsKeyUpdate (*Key, Usb->ParentPortNumber);
+        *Key        = LegacyBiosUsbBbsKeyUpdate (*Key, Usb->InterfaceNumber);
+        HaveUsbNode = TRUE;
+        break;
+
+      case MSG_DEVICE_LOGICAL_UNIT_DP:
+        LogicalUnit = (DEVICE_LOGICAL_UNIT_DEVICE_PATH *) DevicePath;
+        Lun         = LogicalUnit->Lun;
+        break;
+      }
+    }
+
+    DevicePath = NextDevicePathNode (DevicePath);
+  }
+
+  if (!HaveUsbNode) {
+    return FALSE;
+  }
+
+  *Key = LegacyBiosUsbBbsKeyUpdate (*Key, Lun);
+  return TRUE;
+}
+
+STATIC
+BOOLEAN
+LegacyBiosUsbBbsEntryExists (
+  IN BBS_TABLE  *BbsTable,
+  IN UINT32     BbsCount,
+  IN UINTN      Bus,
+  IN UINTN      Device,
+  IN UINTN      Function,
+  IN UINT32     UsbKey
+  )
+{
+  UINT32  Index;
+
+  for (Index = 0; Index < BbsCount; Index++) {
+    if ((BbsTable[Index].Bus == (UINT32) Bus) &&
+        (BbsTable[Index].Device == (UINT32) Device) &&
+        (BbsTable[Index].Function == (UINT32) Function) &&
+        (BbsTable[Index].Class == PCI_CLASS_SERIAL) &&
+        (BbsTable[Index].SubClass == PCI_CLASS_SERIAL_USB) &&
+        (BbsTable[Index].DeviceType == BBS_HARDDISK) &&
+        (BbsTable[Index].IBV1 == CSM_USB_BBS_SIGNATURE) &&
+        (BbsTable[Index].IBV2 == UsbKey)) {
+      return TRUE;
+    }
+  }
+
+  return FALSE;
+}
+
+STATIC
+VOID
+LegacyBiosAppendUsbDiskBbsEntries (
+  IN LEGACY_BIOS_INSTANCE  *Private
+  )
+{
+  EFI_STATUS                Status;
+  UINTN                     HandleCount;
+  EFI_HANDLE                *HandleBuffer;
+  UINTN                     HandleIndex;
+  EFI_BLOCK_IO_PROTOCOL     *BlockIo;
+  EFI_DEVICE_PATH_PROTOCOL  *DevicePath;
+  EFI_DEVICE_PATH_PROTOCOL  *PciDevicePath;
+  EFI_DEVICE_PATH_PROTOCOL  *OriginalPciDevicePath;
+  EFI_PCI_IO_PROTOCOL       *PciIo;
+  EFI_HANDLE                PciHandle;
+  EFI_TO_COMPATIBILITY16_BOOT_TABLE *BootTable;
+  BBS_TABLE                 *BbsTable;
+  UINT32                    BbsIndex;
+  UINT32                    UsbKey;
+  UINTN                     Segment;
+  UINTN                     Bus;
+  UINTN                     Device;
+  UINTN                     Function;
+
+  HandleBuffer = NULL;
+  Status = gBS->LocateHandleBuffer (
+                  ByProtocol,
+                  &gEfiBlockIoProtocolGuid,
+                  NULL,
+                  &HandleCount,
+                  &HandleBuffer
+                  );
+  if (EFI_ERROR (Status)) {
+    return;
+  }
+
+  BootTable = &Private->IntThunk->EfiToLegacy16BootTable;
+  BbsTable  = (BBS_TABLE *)(UINTN) BootTable->BbsTable;
+  BbsIndex  = BootTable->NumberBbsEntries;
+
+  for (HandleIndex = 0; HandleIndex < HandleCount; HandleIndex++) {
+    Status = gBS->HandleProtocol (
+                    HandleBuffer[HandleIndex],
+                    &gEfiBlockIoProtocolGuid,
+                    (VOID **) &BlockIo
+                    );
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    if ((BlockIo->Media == NULL) ||
+        !BlockIo->Media->MediaPresent ||
+        BlockIo->Media->LogicalPartition) {
+      continue;
+    }
+
+    DevicePath = DevicePathFromHandle (HandleBuffer[HandleIndex]);
+    if (!LegacyBiosUsbDevicePathKey (DevicePath, &UsbKey)) {
+      continue;
+    }
+
+    OriginalPciDevicePath = DuplicateDevicePath (DevicePath);
+    if (OriginalPciDevicePath == NULL) {
+      continue;
+    }
+
+    PciDevicePath = OriginalPciDevicePath;
+    PciHandle     = NULL;
+    Status = gBS->LocateDevicePath (
+                    &gEfiPciIoProtocolGuid,
+                    &PciDevicePath,
+                    &PciHandle
+                    );
+    if (!EFI_ERROR (Status)) {
+      Status = gBS->HandleProtocol (
+                      PciHandle,
+                      &gEfiPciIoProtocolGuid,
+                      (VOID **) &PciIo
+                      );
+    }
+    FreePool (OriginalPciDevicePath);
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    Status = PciIo->GetLocation (PciIo, &Segment, &Bus, &Device, &Function);
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    if (LegacyBiosUsbBbsEntryExists (
+          BbsTable,
+          BbsIndex,
+          Bus,
+          Device,
+          Function,
+          UsbKey
+          )) {
+      continue;
+    }
+
+    if (BbsIndex >= MAX_BBS_ENTRIES - 1) {
+      break;
+    }
+
+    ZeroMem (&BbsTable[BbsIndex], sizeof (BBS_TABLE));
+    BbsTable[BbsIndex].BootPriority             = BBS_UNPRIORITIZED_ENTRY;
+    BbsTable[BbsIndex].Bus                      = (UINT32) Bus;
+    BbsTable[BbsIndex].Device                   = (UINT32) Device;
+    BbsTable[BbsIndex].Function                 = (UINT32) Function;
+    BbsTable[BbsIndex].Class                    = PCI_CLASS_SERIAL;
+    BbsTable[BbsIndex].SubClass                 = PCI_CLASS_SERIAL_USB;
+    BbsTable[BbsIndex].DeviceType               = BBS_HARDDISK;
+    BbsTable[BbsIndex].StatusFlags.MediaPresent = 1;
+    BbsTable[BbsIndex].AssignedDriveNumber      = 0xff;
+    BbsTable[BbsIndex].IBV1                     = CSM_USB_BBS_SIGNATURE;
+    BbsTable[BbsIndex].IBV2                     = UsbKey;
+
+    DEBUG ((
+      EFI_D_INFO,
+      "LegacyBios: added USB disk BBS entry %u for %02x/%02x/%02x key %08x\n",
+      (UINTN) BbsIndex,
+      (UINTN) Bus,
+      (UINTN) Device,
+      (UINTN) Function,
+      (UINTN) UsbKey
+      ));
+
+    BbsIndex++;
+  }
+
+  BootTable->NumberBbsEntries = BbsIndex;
+  if (BbsIndex < MAX_BBS_ENTRIES) {
+    BbsTable[BbsIndex].BootPriority = BBS_IGNORE_ENTRY;
+  }
+
+  if (HandleBuffer != NULL) {
+    FreePool (HandleBuffer);
+  }
+}
 
