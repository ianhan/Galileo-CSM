+STATIC
+BOOLEAN
+LegacyBootOptionGetBbsIndex (
+  IN  VOID    *OptionalData,
+  IN  UINTN   OptionalDataSize,
+  OUT UINT16  *BbsIndex
+  )
+{
+  if ((OptionalData == NULL) || (BbsIndex == NULL)) {
+    return FALSE;
+  }
+
+  if (OptionalDataSize == sizeof (UINT16)) {
+    *BbsIndex = *(UINT16 *) OptionalData;
+    return TRUE;
+  }
+
+  if (OptionalDataSize >= sizeof (LEGACY_BOOT_OPTION_BBS_DATA)) {
+    *BbsIndex = ((LEGACY_BOOT_OPTION_BBS_DATA *) OptionalData)->BbsIndex;
+    return TRUE;
+  }
+
+  return FALSE;
+}
