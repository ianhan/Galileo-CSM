+/**
+  Read the BBS index from legacy boot option optional data.
+
+  The GenericBds/rEFInd format stores a BBS_TABLE followed by the UINT16 index.
+**/
+STATIC
+BOOLEAN
+LegacyBmGetBbsIndexFromOptionalData (
+  IN  VOID    *OptionalData,
+  IN  UINTN   OptionalDataSize,
+  OUT UINT16  *BbsIndex
+  )
+{
+  if ((OptionalData == NULL) || (BbsIndex == NULL)) {
+    return FALSE;
+  }
+
+  if (OptionalDataSize != sizeof (LEGACY_BM_BOOT_OPTION_BBS_DATA)) {
+    return FALSE;
+  }
+
+  *BbsIndex = ((LEGACY_BM_BOOT_OPTION_BBS_DATA *) OptionalData)->BbsIndex;
+  return TRUE;
+}
+
+STATIC
+BOOLEAN
+LegacyBmGetBootOptionBbsIndex (
+  IN  EFI_BOOT_MANAGER_LOAD_OPTION  *BootOption,
+  OUT UINT16                        *BbsIndex
+  )
+{
+  if (BootOption == NULL) {
+    return FALSE;
+  }
+
+  return LegacyBmGetBbsIndexFromOptionalData (
+           BootOption->OptionalData,
+           BootOption->OptionalDataSize,
+           BbsIndex
+           );
+}
+
+STATIC
+EFI_STATUS
+LegacyBmSetBootOptionBbsData (
+  IN OUT EFI_BOOT_MANAGER_LOAD_OPTION  *BootOption,
+  IN     BBS_TABLE                     *BbsEntry,
+  IN     UINT16                        BbsIndex
+  )
+{
+  LEGACY_BM_BOOT_OPTION_BBS_DATA  *OptionalData;
+
+  OptionalData = AllocateZeroPool (sizeof (LEGACY_BM_BOOT_OPTION_BBS_DATA));
+  if (OptionalData == NULL) {
+    return EFI_OUT_OF_RESOURCES;
+  }
+
+  CopyMem (&OptionalData->BbsEntry, BbsEntry, sizeof (BBS_TABLE));
+  OptionalData->BbsIndex = BbsIndex;
+
+  if (BootOption->OptionalData != NULL) {
+    FreePool (BootOption->OptionalData);
+  }
+  BootOption->OptionalData     = OptionalData;
+  BootOption->OptionalDataSize = sizeof (LEGACY_BM_BOOT_OPTION_BBS_DATA);
+
+  return EFI_SUCCESS;
+}
