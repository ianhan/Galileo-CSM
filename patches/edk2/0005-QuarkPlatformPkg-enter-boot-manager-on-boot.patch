@@ -124,6 +124,255 @@ HasMediaInFloppy (
 
 }
 
+STATIC
+BOOLEAN
+LegacyBiosDevicePathPrefixMatch (
+  IN  EFI_DEVICE_PATH_PROTOCOL  *Prefix,
+  IN  EFI_DEVICE_PATH_PROTOCOL  *DevicePath,
+  OUT UINTN                     *PrefixSize
+  )
+{
+  UINTN  LocalPrefixSize;
+
+  if ((Prefix == NULL) || (DevicePath == NULL) || (PrefixSize == NULL)) {
+    return FALSE;
+  }
+
+  LocalPrefixSize = GetDevicePathSize (Prefix);
+  if (LocalPrefixSize < END_DEVICE_PATH_LENGTH) {
+    return FALSE;
+  }
+
+  LocalPrefixSize -= END_DEVICE_PATH_LENGTH;
+  if (GetDevicePathSize (DevicePath) < LocalPrefixSize) {
+    return FALSE;
+  }
+
+  if (CompareMem (Prefix, DevicePath, LocalPrefixSize) != 0) {
+    return FALSE;
+  }
+
+  *PrefixSize = LocalPrefixSize;
+  return TRUE;
+}
+
+STATIC
+EFI_STATUS
+LegacyBiosFindPciParent (
+  IN  EFI_DEVICE_PATH_PROTOCOL  *DevicePath,
+  OUT UINTN                     *Bus,
+  OUT UINTN                     *Device,
+  OUT UINTN                     *Function
+  )
+{
+  EFI_STATUS                Status;
+  EFI_HANDLE                *HandleBuffer;
+  UINTN                     HandleCount;
+  UINTN                     Index;
+  EFI_DEVICE_PATH_PROTOCOL  *PciDevicePath;
+  EFI_PCI_IO_PROTOCOL       *PciIo;
+  EFI_PCI_IO_PROTOCOL       *BestPciIo;
+  UINTN                     PrefixSize;
+  UINTN                     BestPrefixSize;
+  UINTN                     Segment;
+
+  if ((DevicePath == NULL) || (Bus == NULL) || (Device == NULL) || (Function == NULL)) {
+    return EFI_INVALID_PARAMETER;
+  }
+
+  HandleBuffer   = NULL;
+  HandleCount    = 0;
+  BestPciIo      = NULL;
+  BestPrefixSize = 0;
+
+  Status = gBS->LocateHandleBuffer (
+                  ByProtocol,
+                  &gEfiPciIoProtocolGuid,
+                  NULL,
+                  &HandleCount,
+                  &HandleBuffer
+                  );
+  if (EFI_ERROR (Status)) {
+    return Status;
+  }
+
+  for (Index = 0; Index < HandleCount; Index++) {
+    PciDevicePath = DevicePathFromHandle (HandleBuffer[Index]);
+    if (!LegacyBiosDevicePathPrefixMatch (PciDevicePath, DevicePath, &PrefixSize)) {
+      continue;
+    }
+
+    Status = gBS->HandleProtocol (
+                    HandleBuffer[Index],
+                    &gEfiPciIoProtocolGuid,
+                    (VOID **) &PciIo
+                    );
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    if (PrefixSize >= BestPrefixSize) {
+      BestPciIo      = PciIo;
+      BestPrefixSize = PrefixSize;
+    }
+  }
+
+  if (HandleBuffer != NULL) {
+    FreePool (HandleBuffer);
+  }
+
+  if (BestPciIo == NULL) {
+    return EFI_NOT_FOUND;
+  }
+
+  Status = BestPciIo->GetLocation (
+                        BestPciIo,
+                        &Segment,
+                        Bus,
+                        Device,
+                        Function
+                        );
+  return Status;
+}
+
+STATIC
+BOOLEAN
+LegacyBiosUsbBbsEntryExists (
+  IN BBS_TABLE  *BbsTable,
+  IN UINTN      BbsCount,
+  IN UINTN      Bus,
+  IN UINTN      Device,
+  IN UINTN      Function
+  )
+{
+  UINTN  Index;
+
+  for (Index = 0; Index < BbsCount; Index++) {
+    if ((BbsTable[Index].BootPriority != BBS_IGNORE_ENTRY) &&
+        (BbsTable[Index].Bus == (UINT32) Bus) &&
+        (BbsTable[Index].Device == (UINT32) Device) &&
+        (BbsTable[Index].Function == (UINT32) Function) &&
+        (BbsTable[Index].DeviceType == BBS_HARDDISK) &&
+        (BbsTable[Index].Class == PCI_CLASS_SERIAL) &&
+        (BbsTable[Index].SubClass == PCI_CLASS_SERIAL_USB)) {
+      return TRUE;
+    }
+  }
+
+  return FALSE;
+}
+
+STATIC
+EFI_STATUS
+LegacyBiosAppendUsbMassStorageBbs (
+  IN LEGACY_BIOS_INSTANCE  *Private,
+  IN BBS_TABLE             *BbsTable
+  )
+{
+  EFI_STATUS                Status;
+  EFI_HANDLE                *HandleBuffer;
+  UINTN                     HandleCount;
+  UINTN                     Index;
+  EFI_DISK_INFO_PROTOCOL    *DiskInfo;
+  EFI_BLOCK_IO_PROTOCOL     *BlockIo;
+  EFI_DEVICE_PATH_PROTOCOL  *DevicePath;
+  UINTN                     Bus;
+  UINTN                     Device;
+  UINTN                     Function;
+  UINTN                     BbsIndex;
+
+  HandleBuffer = NULL;
+  HandleCount  = 0;
+
+  Status = gBS->LocateHandleBuffer (
+                  ByProtocol,
+                  &gEfiDiskInfoProtocolGuid,
+                  NULL,
+                  &HandleCount,
+                  &HandleBuffer
+                  );
+  if (EFI_ERROR (Status)) {
+    return Status;
+  }
+
+  for (Index = 0; Index < HandleCount; Index++) {
+    Status = gBS->HandleProtocol (
+                    HandleBuffer[Index],
+                    &gEfiDiskInfoProtocolGuid,
+                    (VOID **) &DiskInfo
+                    );
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    if (!CompareGuid (&DiskInfo->Interface, &gEfiDiskInfoUsbInterfaceGuid)) {
+      continue;
+    }
+
+    Status = gBS->HandleProtocol (
+                    HandleBuffer[Index],
+                    &gEfiBlockIoProtocolGuid,
+                    (VOID **) &BlockIo
+                    );
+    if (EFI_ERROR (Status) || (BlockIo->Media == NULL) || !BlockIo->Media->MediaPresent) {
+      continue;
+    }
+
+    DevicePath = DevicePathFromHandle (HandleBuffer[Index]);
+    Status = LegacyBiosFindPciParent (DevicePath, &Bus, &Device, &Function);
+    if (EFI_ERROR (Status)) {
+      continue;
+    }
+
+    BbsIndex = (UINTN) Private->IntThunk->EfiToLegacy16BootTable.NumberBbsEntries;
+    if (BbsIndex >= MAX_BBS_ENTRIES - 1) {
+      DEBUG ((EFI_D_WARN, "No room left to add USB mass storage BBS entries\n"));
+      break;
+    }
+
+    if (LegacyBiosUsbBbsEntryExists (BbsTable, BbsIndex, Bus, Device, Function)) {
+      continue;
+    }
+
+    ZeroMem (&BbsTable[BbsIndex], sizeof (BBS_TABLE));
+    BbsTable[BbsIndex].BootPriority             = BBS_UNPRIORITIZED_ENTRY;
+    BbsTable[BbsIndex].Bus                      = (UINT32) Bus;
+    BbsTable[BbsIndex].Device                   = (UINT32) Device;
+    BbsTable[BbsIndex].Function                 = (UINT32) Function;
+    BbsTable[BbsIndex].Class                    = PCI_CLASS_SERIAL;
+    BbsTable[BbsIndex].SubClass                 = PCI_CLASS_SERIAL_USB;
+    BbsTable[BbsIndex].DeviceType               = BBS_HARDDISK;
+    BbsTable[BbsIndex].StatusFlags.OldPosition  = 0;
+    BbsTable[BbsIndex].StatusFlags.Reserved1    = 0;
+    BbsTable[BbsIndex].StatusFlags.Enabled      = 0;
+    BbsTable[BbsIndex].StatusFlags.Failed       = 0;
+    BbsTable[BbsIndex].StatusFlags.MediaPresent = 2;
+    BbsTable[BbsIndex].StatusFlags.Reserved2    = 0;
+    BbsTable[BbsIndex].BootHandlerOffset        = 0;
+    BbsTable[BbsIndex].BootHandlerSegment       = 0;
+    BbsTable[BbsIndex].AssignedDriveNumber      = 0xff;
+
+    DEBUG ((
+      EFI_D_INFO,
+      "Added USB mass storage BBS entry %u for PCI %u:%u.%u\n",
+      (UINTN) BbsIndex,
+      (UINTN) Bus,
+      (UINTN) Device,
+      (UINTN) Function
+      ));
+
+    BbsIndex++;
+    BbsTable[BbsIndex].BootPriority = BBS_IGNORE_ENTRY;
+    Private->IntThunk->EfiToLegacy16BootTable.NumberBbsEntries = (UINT32) BbsIndex;
+  }
+
+  if (HandleBuffer != NULL) {
+    FreePool (HandleBuffer);
+  }
+
+  return EFI_SUCCESS;
+}
+
 
 /**
   Complete build of BBS TABLE.
@@ -252,6 +501,8 @@ LegacyBiosBuildBbs (
     }
   }
 
+  LegacyBiosAppendUsbMassStorageBbs (Private, BbsTable);
+
   return EFI_SUCCESS;
 
 }
