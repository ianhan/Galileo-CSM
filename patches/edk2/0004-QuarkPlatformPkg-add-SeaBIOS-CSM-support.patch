 }
@@ -156,7 +159,11 @@ WritePirq (
     return EFI_INVALID_PARAMETER;
   }
 
-  PciWrite8 (GetAddress (PirqNumber), PirqData);
+  PciAndThenOr8 (
+    GetAddress (PirqNumber),
+    (UINT8) ~(BIT7 | B_QNC_LPC_PIRQX_ROUT),
+    (UINT8) (PirqData & B_QNC_LPC_PIRQX_ROUT)
+    );
   return EFI_SUCCESS;
 }
 
