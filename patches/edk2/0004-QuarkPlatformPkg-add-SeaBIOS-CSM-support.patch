diff --git a/OvmfPkg/Csm/CsmSupportLib/LegacyPlatform.c b/OvmfPkg/Csm/CsmSupportLib/LegacyPlatform.c
index a07bb82da7..0105284d78 100644
--- a/OvmfPkg/Csm/CsmSupportLib/LegacyPlatform.c
+++ b/OvmfPkg/Csm/CsmSupportLib/LegacyPlatform.c
@@ -48,11 +48,16 @@ EFI_LEGACY_IRQ_PRIORITY_TABLE_ENTRY IrqPriorityTable[MAX_IRQ_PRIORITY_ENTRIES] =
   {0x00,0}
 };
 
+#define QUARK_DEVFN(Device, Function) \
+  (UINT8) (((Device) << 3) | (Function))
+
+#define QUARK_PIRQ_ENTRY(Register) \
+  { (Register), QUARK_PIRQ_MASK }
+
 //
-// PIRQ Table
-// - Slot numbering will be used to update the bus number and determine bridge
-//   to check to get bus number.  The Slot number - 1 is an index into a decode
-//   table to get the bridge information.
+// Quark/Galileo PCI IRQ routing. Device fields are PCI devfns.
+// Root ports are marked as slots so LegacyBiosDxe can translate devices behind
+// PCIe bridges back to the root-port PIRQ links.
 //
 EFI_LEGACY_PIRQ_TABLE PirqTableHead = {
   {
@@ -61,10 +66,15 @@ EFI_LEGACY_PIRQ_TABLE PirqTableHead = {
     0x01,             // UINT8   MajorVersion
     0x0000,           // UINT16  TableSize
     0x00,             // UINT8   Bus
-    0x08,             // UINT8   DevFun
+    QUARK_DEVFN (
+      PCI_DEVICE_NUMBER_QNC_LPC,
+      PCI_FUNCTION_NUMBER_QNC_LPC
+      ),
+                      // UINT8   DevFun
     0x0000,           // UINT16  PciOnlyIrq
     0x8086,           // UINT16  CompatibleVid
-    0x122e,           // UINT16  CompatibleDid
+    QUARK_V_LPC_DEVICE_ID_0,
+                      // UINT16  CompatibleDid
     0x00000000,       // UINT32  Miniport
     {                 // UINT8   Reserved[11]
       0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
@@ -76,12 +86,66 @@ EFI_LEGACY_PIRQ_TABLE PirqTableHead = {
     //           -- Pin 1 --   -- Pin 2 --   -- Pin 3 --   -- Pin 4 --
     // Bus  Dev   Reg   Map     Reg   Map     Reg   Map     Reg   Map
     //
-    {0x00,0x08,{{0x60,0xDEB8},{0x61,0xDEB8},{0x62,0xDEB8},{0x63,0xDEB8}},0x00,0x00},
-    {0x00,0x10,{{0x61,0xDEB8},{0x62,0xDEB8},{0x63,0xDEB8},{0x60,0xDEB8}},0x01,0x00},
-    {0x00,0x18,{{0x62,0xDEB8},{0x63,0xDEB8},{0x60,0xDEB8},{0x61,0xDEB8}},0x02,0x00},
-    {0x00,0x20,{{0x63,0xDEB8},{0x60,0xDEB8},{0x61,0xDEB8},{0x62,0xDEB8}},0x03,0x00},
-    {0x00,0x28,{{0x60,0xDEB8},{0x61,0xDEB8},{0x62,0xDEB8},{0x63,0xDEB8}},0x04,0x00},
-    {0x00,0x30,{{0x61,0xDEB8},{0x62,0xDEB8},{0x63,0xDEB8},{0x60,0xDEB8}},0x05,0x00},
+    {
+      PCI_BUS_NUMBER_QNC,
+      QUARK_DEVFN (PCI_DEVICE_NUMBER_QNC_IOSF2AHB_0, PCI_FUNCTION_NUMBER_QNC_IOSF2AHB),
+      {
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQA_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQB_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQC_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQD_ROUT)
+      },
+      0x00,
+      0x00
+    },
+    {
+      PCI_BUS_NUMBER_QNC,
+      QUARK_DEVFN (PCI_DEVICE_NUMBER_QNC_IOSF2AHB_1, PCI_FUNCTION_NUMBER_QNC_IOSF2AHB),
+      {
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQA_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQB_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQC_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQD_ROUT)
+      },
+      0x00,
+      0x00
+    },
+    {
+      PCI_BUS_NUMBER_QNC,
+      QUARK_DEVFN (PCI_DEVICE_NUMBER_PCIE_ROOTPORT, PCI_FUNCTION_NUMBER_PCIE_ROOTPORT_0),
+      {
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQE_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQF_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQG_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQH_ROUT)
+      },
+      0x01,
+      0x00
+    },
+    {
+      PCI_BUS_NUMBER_QNC,
+      QUARK_DEVFN (PCI_DEVICE_NUMBER_PCIE_ROOTPORT, PCI_FUNCTION_NUMBER_PCIE_ROOTPORT_1),
+      {
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQF_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQG_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQH_ROUT),
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQE_ROUT)
+      },
+      0x02,
+      0x00
+    },
+    {
+      PCI_BUS_NUMBER_QNC,
+      QUARK_DEVFN (PCI_DEVICE_NUMBER_QNC_LPC, PCI_FUNCTION_NUMBER_QNC_LPC),
+      {
+        QUARK_PIRQ_ENTRY (R_QNC_LPC_PIRQA_ROUT),
+        {0x00, 0x0000},
+        {0x00, 0x0000},
+        {0x00, 0x0000}
+      },
+      0x00,
+      0x00
+    },
   }
 };
 
@@ -235,8 +299,6 @@ GetSelectedVgaDeviceInfo (
   UINTN                     Index;
   EFI_PCI_IO_PROTOCOL       *PciIo;
   PCI_TYPE00                Pci;
-  UINT8                     MinBus;
-  UINT8                     MaxBus;
   UINTN                     Segment;
   UINTN                     Bus;
   UINTN                     Device;
@@ -257,11 +319,6 @@ GetSelectedVgaDeviceInfo (
   HandleBuffer = NULL;
   SelectedAddress = PCI_LIB_ADDRESS(0xff, 0x1f, 0x7, 0);
 
-  //
-  // The bus range to search for a VGA device in.
-  //
-  MinBus = MaxBus = 0;
-
   //
   // Start to check all the pci io to find all possible VGA device
   //
@@ -282,10 +339,10 @@ GetSelectedVgaDeviceInfo (
     Status = gBS->HandleProtocol (HandleBuffer[Index], &gEfiPciIoProtocolGuid, (VOID**)&PciIo);
     if (!EFI_ERROR (Status)) {
       //
-      // Detemine if this is in the correct bus range.
+      // Determine if this is a reachable PCI device.
       //
       Status = PciIo->GetLocation (PciIo, &Segment, &Bus, &Device, &Function);
-      if (EFI_ERROR(Status) || (Bus < MinBus || Bus > MaxBus)) {
+      if (EFI_ERROR(Status)) {
         continue;
       }
 
@@ -811,6 +868,20 @@ GetPlatformInfo (
   };
 }
 
+STATIC
+UINT8
+PirqRegisterToIndex (
+  IN UINT8  PirqRegister
+  )
+{
+  if ((PirqRegister >= R_QNC_LPC_PIRQA_ROUT) &&
+      (PirqRegister <= R_QNC_LPC_PIRQH_ROUT)) {
+    return (UINT8) (PirqRegister - R_QNC_LPC_PIRQA_ROUT);
+  }
+
+  return MAX_UINT8;
+}
+
 /**
   Translates the given PIRQ accounting for bridge.
   This function translates the given PIRQ back through all buses, if required,
@@ -841,10 +912,14 @@ TranslatePirq (
   EFI_LEGACY_INTERRUPT_PROTOCOL      *LegacyInterrupt;
   EFI_STATUS                         Status;
   UINTN                              Index;
+  UINTN                              ExactPass;
   UINTN                              Index1;
   UINT8                              LocalPirq;
+  UINT8                              PirqRegister;
   UINT8                              PirqData;
   UINT8                              MatchData;
+  UINT8                              DevFun;
+  EFI_LEGACY_PIRQ_ENTRY              *PirqEntry;
 
   Status = gBS->LocateProtocol (
                   &gEfiLegacyInterruptProtocolGuid,
@@ -852,14 +927,39 @@ TranslatePirq (
                   (VOID**)&LegacyInterrupt
                   );
   ASSERT_EFI_ERROR (Status);
-  LocalPirq = (UINT8) (*Pirq);
-
-  for (Index = 0; Index < MAX_IRQ_ROUTING_ENTRIES; Index++) {
-    if ((PirqTableHead.IrqRoutingEntry[Index].Bus == PciBus) &&
-        (PirqTableHead.IrqRoutingEntry[Index].Device == PciDevice)) {
-      LocalPirq = (UINT8) (PirqTableHead.IrqRoutingEntry[Index].PirqEntry[LocalPirq].Pirq & 0x0f);
-      if (LocalPirq > 4) {
-        LocalPirq -= 4;
+
+  if (*Pirq >= 4) {
+    return EFI_INVALID_PARAMETER;
+  }
+
+  //
+  // LegacyBiosDxe passes PciDevice as a shifted devfn base.
+  //
+  DevFun = (UINT8) (PciDevice | PciFunction);
+
+  for (ExactPass = 0; ExactPass < 2; ExactPass++) {
+    for (Index = 0; Index < MAX_IRQ_ROUTING_ENTRIES; Index++) {
+      if (PirqTableHead.IrqRoutingEntry[Index].Bus != PciBus) {
+        continue;
+      }
+
+      if (ExactPass == 0) {
+        if (PirqTableHead.IrqRoutingEntry[Index].Device != DevFun) {
+          continue;
+        }
+      } else if ((PirqTableHead.IrqRoutingEntry[Index].Device & 0xf8) != PciDevice) {
+        continue;
+      }
+
+      PirqEntry = &PirqTableHead.IrqRoutingEntry[Index].PirqEntry[*Pirq];
+      if ((PirqEntry->Pirq == 0) && (PirqEntry->IrqMask == 0)) {
+        return EFI_NOT_FOUND;
+      }
+
+      PirqRegister = PirqEntry->Pirq;
+      LocalPirq = PirqRegisterToIndex (PirqRegister);
+      if (LocalPirq == MAX_UINT8) {
+        return EFI_NOT_FOUND;
       }
 
       LegacyInterrupt->ReadPirq (LegacyInterrupt, LocalPirq, &PirqData);
@@ -882,7 +982,7 @@ TranslatePirq (
         if (PirqData == 0) {
 
           //
-          // No unused interrpts, so start reusing them.
+          // No unused interrupts, so start reusing them.
           //
           MatchData = (UINT8) (~MatchData);
         }
@@ -890,10 +990,11 @@ TranslatePirq (
 
       *PciIrq = PirqData;
       *Pirq   = LocalPirq;
+      return EFI_SUCCESS;
     }
   }
 
-  return EFI_SUCCESS;
+  return EFI_NOT_FOUND;
 }
 
 
