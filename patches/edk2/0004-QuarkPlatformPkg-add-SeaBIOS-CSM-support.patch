 }
 
-/**
-  Find the PC-AT ROM Image in the raw PCI Option ROM. Also return the
-  related information from the header.
+/**
+  Find the PC-AT ROM Image in the raw PCI Option ROM. Also return the
+  related information from the header.
 
   @param  Csm16Revision           The PCI interface version of underlying CSM16
   @param  VendorId                Vendor ID of the PCI device
@@ -2260,10 +2260,10 @@ LegacyBiosInstallRom (
   OUT UINT8                             *DiskEnd, OPTIONAL
   OUT VOID                              **RomShadowAddress OPTIONAL
   )
-{
-  EFI_STATUS            Status;
-  EFI_STATUS            PciEnableStatus;
-  EFI_PCI_IO_PROTOCOL   *PciIo;
+{
+  EFI_STATUS            Status;
+  EFI_STATUS            PciEnableStatus;
+  EFI_PCI_IO_PROTOCOL   *PciIo;
   UINT8                 LocalDiskStart;
   UINT8                 LocalDiskEnd;
   UINTN                 Segment;
@@ -2284,18 +2284,22 @@ LegacyBiosInstallRom (
   UINTN                 RuntimeAddress;
   EFI_PHYSICAL_ADDRESS  PhysicalAddress;
   UINT32                Granularity;
-
-  PciIo           = NULL;
-  LocalDiskStart  = 0;
-  LocalDiskEnd    = 0;
-  Segment         = 0;
-  Bus             = 0;
-  Device          = 0;
-  Function        = 0;
-  VideoMode       = 0;
-  OldVideoMode    = 0;
-  PhysicalAddress = 0;
-  MaxRomAddr      = PcdGet32 (PcdEndOpromShadowAddress);
+  UINT64                Supports;
+  UINT64                EnableAttributes;
+
+  PciIo              = NULL;
+  LocalDiskStart     = 0;
+  LocalDiskEnd       = 0;
+  Segment            = 0;
+  Bus                = 0;
+  Device             = 0;
+  Function           = 0;
+  VideoMode          = 0;
+  OldVideoMode       = 0;
+  PhysicalAddress    = 0;
+  MaxRomAddr         = PcdGet32 (PcdEndOpromShadowAddress);
+  Supports        = 0;
+  EnableAttributes = 0;
 
   if ((Private->Legacy16Table->TableLength >= OFFSET_OF(EFI_COMPATIBILITY16_TABLE, HiPermanentMemoryAddress)) &&
       (Private->Legacy16Table->UmaAddress != 0) &&
@@ -2484,25 +2488,58 @@ LegacyBiosInstallRom (
                     );
     ASSERT_EFI_ERROR (Status);
 
-    //
-    // Enable command register.
-    //
-    PciEnableStatus = PciIo->Attributes (
-                               PciIo,
-                               EfiPciIoAttributeOperationEnable,
-                               EFI_PCI_DEVICE_ENABLE,
-                               NULL
-                               );
-
-    PciIo->GetLocation (
-             PciIo,
-             &Segment,
-             &Bus,
-             &Device,
-             &Function
-             );
-    DEBUG ((EFI_D_INFO, "Shadowing OpROM on the PCI device %x/%x/%x\n", Bus, Device, Function));
-  }
+    EnableAttributes = EFI_PCI_DEVICE_ENABLE;
+    if (PciHandle == mVgaHandle) {
+      Status = PciIo->Attributes (
+                        PciIo,
+                        EfiPciIoAttributeOperationSupported,
+                        0,
+                        &Supports
+                        );
+      if (!EFI_ERROR (Status)) {
+        if ((Supports & EFI_PCI_IO_ATTRIBUTE_VGA_MEMORY) != 0) {
+          EnableAttributes |= EFI_PCI_IO_ATTRIBUTE_VGA_MEMORY;
+        }
+
+        if ((Supports & EFI_PCI_IO_ATTRIBUTE_VGA_IO) != 0) {
+          EnableAttributes |= EFI_PCI_IO_ATTRIBUTE_VGA_IO;
+        } else if ((Supports & EFI_PCI_IO_ATTRIBUTE_VGA_IO_16) != 0) {
+          EnableAttributes |= EFI_PCI_IO_ATTRIBUTE_VGA_IO_16;
+        }
+
+        DEBUG ((
+          EFI_D_INFO,
+          " VGA OpROM attributes supported=%x enable=%x\n",
+          (UINTN) Supports,
+          (UINTN) EnableAttributes
+          ));
+      } else {
+        DEBUG ((EFI_D_ERROR, " VGA OpROM attributes query failed: %r\n", Status));
+      }
+    }
+
+    //
+    // Enable command register and, for VGA, legacy VGA decode.
+    //
+    PciEnableStatus = PciIo->Attributes (
+                               PciIo,
+                               EfiPciIoAttributeOperationEnable,
+                               EnableAttributes,
+                               NULL
+                               );
+    if (PciHandle == mVgaHandle) {
+      DEBUG ((EFI_D_INFO, " VGA OpROM enable status: %r\n", PciEnableStatus));
+    }
+
+    PciIo->GetLocation (
+             PciIo,
+             &Segment,
+             &Bus,
+             &Device,
+             &Function
+             );
+    DEBUG ((EFI_D_INFO, "Shadowing OpROM on the PCI device %x/%x/%x\n", Bus, Device, Function));
+  }
 
   mIgnoreBbsUpdateFlag  = FALSE;
   Regs.X.AX             = Legacy16DispatchOprom;
diff --git a/OvmfPkg/Csm/CsmSupportLib/CsmSupportLib.c b/OvmfPkg/Csm/CsmSupportLib/CsmSupportLib.c
index 533b078593..b66e22fe6e 100644
--- a/OvmfPkg/Csm/CsmSupportLib/CsmSupportLib.c
+++ b/OvmfPkg/Csm/CsmSupportLib/CsmSupportLib.c
@@ -15,18 +15,24 @@
   @retval EFI_SUCCESS   The constructor always returns RETURN_SUCCESS.
 
 **/
-RETURN_STATUS
-EFIAPI
-CsmSupportLibConstructor (
-  VOID
-  )
-{
-  LegacyRegionInit ();
-
-  LegacyInterruptInstall ();
-
-  LegacyBiosPlatformInstall ();
-
-  return EFI_SUCCESS;
-}
+RETURN_STATUS
+EFIAPI
+CsmSupportLibConstructor (
+  VOID
+  )
+{
+  EFI_STATUS  Status;
+
+  Status = LegacyInterruptInstall ();
+  if (EFI_ERROR (Status)) {
+    return Status;
+  }
+
+  Status = LegacyBiosPlatformInstall ();
+  if (EFI_ERROR (Status)) {
+    return Status;
+  }
+
+  return EFI_SUCCESS;
+}
 
