-#define LEGACY_INT_BUS  0
-#define LEGACY_INT_DEV_PIIX4  0x01
-#define LEGACY_INT_DEV_Q35    0x1f
-#define LEGACY_INT_FUNC 0
-
-#define PIRQN           0x00  // PIRQ Null
-#define PIRQA           0x60
-#define PIRQB           0x61
-#define PIRQC           0x62
-#define PIRQD           0x63
-#define PIRQE           0x68
