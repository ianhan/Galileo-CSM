From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Galileo CSM Workspace <galileo-csm@example.invalid>
Date: Tue, 21 Apr 2026 17:45:00 -0600
Subject: [PATCH] SeaBIOS: use CSM BBS priority for USB storage

In CSM mode, edk2 publishes USB mass-storage media as BBS hard-disk
entries from its already-connected BlockIo handles. SeaBIOS must not run
USB discovery from Legacy16UpdateBbs while edk2 owns the USB controller.

Track SeaBIOS USB drives during normal PrepareToBoot hardware discovery
and reapply the selected CSM BBS priority to the matching INT 13h drive
before the SeaBIOS boot menu and final boot ordering run.

diff --git a/src/boot.c b/src/boot.c
index 5c37dafd..fb4307ca 100644
--- a/src/boot.c
+++ b/src/boot.c
@@ -421,6 +421,12 @@ build_usb_path(char *buf, int max, struct usbhub_s *hub)
 
 int bootprio_find_usb(struct usbdevice_s *usbdev, int lun)
 {
+    if (CONFIG_CSM && usbdev->hub->cntl->pci) {
+        int prio = csm_bootprio_pci(usbdev->hub->cntl->pci);
+        if (prio >= 0)
+            return prio;
+    }
+
     if (!CONFIG_BOOTORDER)
         return -1;
     // Find usb - examples:
@@ -522,26 +528,11 @@ static struct hlist_head BootList VARVERIFY32INIT;
 #define IPL_TYPE_HALT        0xf0
 
 static void
-bootentry_add(int type, int prio, u32 data, const char *desc)
+bootentry_insert(struct hlist_head *list, struct bootentry_s *be)
 {
-    if (! CONFIG_BOOT)
-        return;
-    struct bootentry_s *be = malloc_tmp(sizeof(*be));
-    if (!be) {
-        warn_noalloc();
-        return;
-    }
-    be->type = type;
-    be->priority = prio;
-    be->data = data;
-    be->description = desc ?: "?";
-    dprintf(3, "Registering bootable: %s (type:%d prio:%d data:%x)\n"
-            , be->description, type, prio, data);
-
-    // Add entry in sorted order.
     struct hlist_node **pprev;
     struct bootentry_s *pos;
-    hlist_for_each_entry_pprev(pos, pprev, &BootList, node) {
+    hlist_for_each_entry_pprev(pos, pprev, list, node) {
         if (be->priority < pos->priority)
             break;
         if (be->priority > pos->priority)
@@ -559,6 +550,27 @@ bootentry_add(int type, int prio, u32 data, const char *desc)
     hlist_add(&be->node, pprev);
 }
 
+static void
+bootentry_add(int type, int prio, u32 data, const char *desc)
+{
+    if (! CONFIG_BOOT)
+        return;
+    struct bootentry_s *be = malloc_tmp(sizeof(*be));
+    if (!be) {
+        warn_noalloc();
+        return;
+    }
+    be->type = type;
+    be->priority = prio;
+    be->data = data;
+    be->description = desc ?: "?";
+    dprintf(3, "Registering bootable: %s (type:%d prio:%d data:%x)\n"
+            , be->description, type, prio, data);
+
+    // Add entry in sorted order.
+    bootentry_insert(&BootList, be);
+}
+
 // Return the given priority if it's set - defaultprio otherwise.
 static inline int defPrio(int priority, int defaultprio) {
     return (priority < 0) ? defaultprio : priority;
@@ -621,6 +633,27 @@ boot_add_cbfs(void *data, const char *desc, int prio)
     bootentry_add(IPL_TYPE_CBFS, defPrio(prio, DEFAULT_PRIO), (u32)data, desc);
 }
 
+void
+boot_update_csm_priorities(void)
+{
+    if (!CONFIG_CSM)
+        return;
+
+    struct hlist_head newlist = { };
+    struct bootentry_s *pos;
+    struct hlist_node *next;
+    hlist_for_each_entry_safe(pos, next, &BootList, node) {
+        hlist_del(&pos->node);
+        if (pos->type == IPL_TYPE_HARDDISK) {
+            int prio = csm_bootprio_drive(pos->drive);
+            if (prio >= 0)
+                pos->priority = prio;
+        }
+        bootentry_insert(&newlist, pos);
+    }
+    BootList = newlist;
+}
+
 
