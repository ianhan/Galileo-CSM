diff --git a/src/post.c b/src/post.c
index f93106a1..55c18e46 100644
--- a/src/post.c
+++ b/src/post.c
@@ -161,35 +161,54 @@ void
 prepareboot(void)
 {
     // Change TPM phys. presence state befor leaving BIOS
+    printf("CSMDBG: prepareboot begin\n");
+    printf("CSMDBG: before tpm_prepboot\n");
     tpm_prepboot();
+    printf("CSMDBG: after tpm_prepboot\n");
 
     // Run BCVs
+    printf("CSMDBG: before bcv_prepboot\n");
     bcv_prepboot();
+    printf("CSMDBG: after bcv_prepboot\n");
 
     // Finalize data structures before boot
+    printf("CSMDBG: before cdrom_prepboot\n");
     cdrom_prepboot();
+    printf("CSMDBG: after cdrom_prepboot\n");
+    printf("CSMDBG: before pmm_prepboot\n");
     pmm_prepboot();
+    printf("CSMDBG: after pmm_prepboot\n");
+    printf("CSMDBG: before malloc_prepboot\n");
     malloc_prepboot();
+    printf("CSMDBG: after malloc_prepboot\n");
+    printf("CSMDBG: before e820_prepboot\n");
     e820_prepboot();
+    printf("CSMDBG: after e820_prepboot\n");
 
     HaveRunPost = 2;
 
     // Setup bios checksum.
+    printf("CSMDBG: before BIOS checksum update\n");
     BiosChecksum -= checksum((u8*)BUILD_BIOS_ADDR, BUILD_BIOS_SIZE);
+    printf("CSMDBG: prepareboot end\n");
 }
 
 // Begin the boot process by invoking an int0x19 in 16bit mode.
 void VISIBLE32FLAT
 startBoot(void)
 {
+    printf("CSMDBG: startBoot entry\n");
+
     // Clear low-memory allocations (required by PMM spec).
     memset((void*)BUILD_STACK_ADDR, 0, BUILD_EBDA_MINIMUM - BUILD_STACK_ADDR);
 
     dprintf(3, "Jump to int19\n");
+    printf("CSMDBG: before int19\n");
     struct bregs br;
     memset(&br, 0, sizeof(br));
     br.flags = F_IF;
     call16_int(0x19, &br);
+    printf("CSMDBG: int19 returned flags=%04x ax=%04x\n", br.flags, br.ax);
 }
 
