+#define CSM_MAX_BBS_ENTRIES 0x100
+
+char CsmUsbDriveDesc[] VARFSEG = "USB Mass Storage";
+
+struct csm_usb_drive_s {
+    struct drive_s *drive;
+    struct pci_device *pci;
+    int lun;
+    int bbs_index;
+    struct csm_usb_drive_s *next;
+};
+
+static struct csm_usb_drive_s *CsmUsbDrives;
+static int CsmBasicSetupDone;
+
 extern void __csm_return(struct bregs *regs) __noreturn;
 
 static void
@@ -59,6 +77,101 @@ csm_return(struct bregs *regs)
     __csm_return(regs);
 }
 
+static void
+csm_setup_basic(void)
+{
+    if (CsmBasicSetupDone)
+        return;
+    CsmBasicSetupDone = 1;
+
+    thread_setup();
+    mathcp_setup();
+    timer_setup();
+    clock_setup();
+}
+
+void
+csm_register_usb_drive(struct usbdevice_s *usbdev, int lun, struct drive_s *drive)
+{
+    if (!CONFIG_CSM || !usbdev || !drive || !usbdev->hub || !usbdev->hub->cntl
+        || !usbdev->hub->cntl->pci)
+        return;
+
+    struct csm_usb_drive_s **pprev = &CsmUsbDrives;
+    for (;;) {
+        struct csm_usb_drive_s *pos = *pprev;
+        if (!pos)
+            break;
+        if (pos->drive == drive)
+            return;
+        pprev = &pos->next;
+    }
+
+    struct csm_usb_drive_s *entry = malloc_tmp(sizeof(*entry));
+    if (!entry) {
+        warn_noalloc();
+        return;
+    }
+    memset(entry, 0, sizeof(*entry));
+    entry->drive = drive;
+    entry->pci = usbdev->hub->cntl->pci;
+    entry->lun = lun;
+    entry->bbs_index = -1;
+    *pprev = entry;
+
+    dprintf(3, "CSM registered USB drive %p on PCI %02x:%02x.%x lun %d\n",
+            drive, pci_bdf_to_bus(entry->pci->bdf),
+            pci_bdf_to_dev(entry->pci->bdf), pci_bdf_to_fn(entry->pci->bdf),
+            lun);
+}
+
+static void
+csm_append_usb_drive_bbs(struct csm_usb_drive_s *drive)
+{
+    if (!csm_boot_table || !drive || !drive->pci)
+        return;
+
+    u32 index = csm_boot_table->NumberBbsEntries;
+    if (index >= CSM_MAX_BBS_ENTRIES) {
+        dprintf(1, "No room left to add CSM USB BBS entry\n");
+        drive->bbs_index = -1;
+        return;
+    }
+
+    BBS_TABLE *bbs = (void *)csm_boot_table->BbsTable;
+    memset(&bbs[index], 0, sizeof(bbs[index]));
+    bbs[index].BootPriority = BBS_UNPRIORITIZED_ENTRY;
+    bbs[index].Bus = pci_bdf_to_bus(drive->pci->bdf);
+    bbs[index].Device = pci_bdf_to_dev(drive->pci->bdf);
+    bbs[index].Function = pci_bdf_to_fn(drive->pci->bdf);
+    bbs[index].Class = PCI_CLASS_SERIAL_USB >> 8;
+    bbs[index].SubClass = PCI_CLASS_SERIAL_USB & 0xff;
+    bbs[index].DeviceType = BBS_HARDDISK;
+    bbs[index].StatusFlags.MediaPresent = 2;
+    bbs[index].MfgStringSegment = FLATPTR_TO_SEG((void*)CsmUsbDriveDesc);
+    bbs[index].MfgStringOffset = FLATPTR_TO_OFFSET((void*)CsmUsbDriveDesc);
+    bbs[index].DescStringSegment = FLATPTR_TO_SEG((void*)CsmUsbDriveDesc);
+    bbs[index].DescStringOffset = FLATPTR_TO_OFFSET((void*)CsmUsbDriveDesc);
+    bbs[index].AssignedDriveNumber = 0xff;
+
+    drive->bbs_index = index;
+    csm_boot_table->NumberBbsEntries = index + 1;
+    if (csm_boot_table->NumberBbsEntries < CSM_MAX_BBS_ENTRIES)
+        bbs[csm_boot_table->NumberBbsEntries].BootPriority = BBS_IGNORE_ENTRY;
+
+    dprintf(3, "CSM added USB BBS entry %d for drive %p PCI %02x:%02x.%x\n",
+            index, drive->drive, bbs[index].Bus, bbs[index].Device,
+            bbs[index].Function);
+}
+
+static void
+csm_export_usb_drives(void)
+{
+    struct csm_usb_drive_s *pos;
+    for (pos = CsmUsbDrives; pos; pos = pos->next)
+        csm_append_usb_drive_bbs(pos);
+}
