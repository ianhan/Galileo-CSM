+++ b/src/boot.c
@@ -522,26 +522,11 @@ static struct hlist_head BootList VARVERIFY32INIT;
 #define IPL_TYPE_HALT        0xf0
 
 static void
-bootentry_add(int type, int prio, u32 data, const char *desc)
+bootentry_insert(struct hlist_head *list, struct bootentry_s *be)
 {
-    if (! CONFIG_BOOT)
-        return;
-    struct bootentry_s *be = malloc_tmp(sizeof(*be));
-    if (!be) {
-        warn_noalloc();
-        return;
-    }
-    be->type = type;
-    be->priority = prio;
-    be->data = data;
-    be->description = desc ?: "?";
-    dprintf(3, "Registering bootable: %s (type:%d prio:%d data:%x)\n"
-            , be->description, type, prio, data);
-
-    // Add entry in sorted order.
     struct hlist_node **pprev;
     struct bootentry_s *pos;
-    hlist_for_each_entry_pprev(pos, pprev, &BootList, node) {
+    hlist_for_each_entry_pprev(pos, pprev, list, node) {
         if (be->priority < pos->priority)
             break;
         if (be->priority > pos->priority)
@@ -559,6 +544,27 @@ bootentry_add(int type, int prio, u32 data, const char *desc)
     hlist_add(&be->node, pprev);
 }
 
+static void
+bootentry_add(int type, int prio, u32 data, const char *desc)
+{
+    if (! CONFIG_BOOT)
+        return;
+    struct bootentry_s *be = malloc_tmp(sizeof(*be));
+    if (!be) {
+        warn_noalloc();
+        return;
+    }
+    be->type = type;
+    be->priority = prio;
+    be->data = data;
+    be->description = desc ?: "?";
+    dprintf(3, "Registering bootable: %s (type:%d prio:%d data:%x)\n"
+            , be->description, type, prio, data);
+
+    // Add entry in sorted order.
+    bootentry_insert(&BootList, be);
+}
+
 // Return the given priority if it's set - defaultprio otherwise.
 static inline int defPrio(int priority, int defaultprio) {
     return (priority < 0) ? defaultprio : priority;
@@ -621,6 +627,27 @@ boot_add_cbfs(void *data, const char *desc, int prio)
     bootentry_add(IPL_TYPE_CBFS, defPrio(prio, DEFAULT_PRIO), (u32)data, desc);
 }
 
+void
+boot_update_csm_priorities(void)
+{
+    if (!CONFIG_CSM)
+        return;
+
+    struct hlist_head newlist = { };
+    struct bootentry_s *pos;
+    struct hlist_node *next;
+    hlist_for_each_entry_safe(pos, next, &BootList, node) {
+        hlist_del(&pos->node);
+        if (pos->type == IPL_TYPE_HARDDISK) {
+            int prio = csm_bootprio_drive(pos->drive);
+            if (prio >= 0)
+                pos->priority = prio;
+        }
+        bootentry_insert(&newlist, pos);
+    }
+    BootList = newlist;
+}
+
 
 /****************************************************************
  * Keyboard calls
@@ -787,6 +814,9 @@ interactive_bootmenu(void)
     }
     printf("\n");
 
+    printf("CSMDBG: bootmenu selected '%s' type=%d prio=%d data=%x\n",
+            boot->description, boot->type, boot->priority, boot->data);
+
     // Find entry and make top priority.
     hlist_del(&boot->node);
     boot->priority = 0;
@@ -823,6 +853,8 @@ bcv_prepboot(void)
     if (! CONFIG_BOOT)
         return;
 
+    printf("CSMDBG: bcv_prepboot begin\n");
+
     int haltprio = find_prio("HALT");
     if (haltprio >= 0)
         bootentry_add(IPL_TYPE_HALT, haltprio, 0, "HALT");
@@ -830,21 +862,33 @@ bcv_prepboot(void)
     // Map drives and populate BEV list
     struct bootentry_s *pos;
     hlist_for_each_entry(pos, &BootList, node) {
+        printf("CSMDBG: bcv_prepboot entry '%s' type=%d prio=%d data=%x\n",
+                pos->description, pos->type, pos->priority, pos->data);
         switch (pos->type) {
         case IPL_TYPE_BCV:
+            printf("CSMDBG: before call_bcv %04x:%04x\n",
+                    pos->vector.seg, pos->vector.offset);
             call_bcv(pos->vector.seg, pos->vector.offset);
+            printf("CSMDBG: after call_bcv %04x:%04x\n",
+                    pos->vector.seg, pos->vector.offset);
             add_bev(IPL_TYPE_HARDDISK, 0);
             break;
         case IPL_TYPE_FLOPPY:
+            printf("CSMDBG: before map_floppy_drive %p\n", pos->drive);
             map_floppy_drive(pos->drive);
+            printf("CSMDBG: after map_floppy_drive %p\n", pos->drive);
             add_bev(IPL_TYPE_FLOPPY, 0);
             break;
         case IPL_TYPE_HARDDISK:
+            printf("CSMDBG: before map_hd_drive %p\n", pos->drive);
             map_hd_drive(pos->drive);
+            printf("CSMDBG: after map_hd_drive %p\n", pos->drive);
             add_bev(IPL_TYPE_HARDDISK, 0);
             break;
         case IPL_TYPE_CDROM:
+            printf("CSMDBG: before map_cd_drive %p\n", pos->drive);
             map_cd_drive(pos->drive);
+            printf("CSMDBG: after map_cd_drive %p\n", pos->drive);
             // NO BREAK
         default:
             add_bev(pos->type, pos->data);
@@ -855,6 +899,8 @@ bcv_prepboot(void)
     // If nothing added a floppy/hd boot - add it manually.
     add_bev(IPL_TYPE_FLOPPY, 0);
     add_bev(IPL_TYPE_HARDDISK, 0);
+    printf("CSMDBG: bcv_prepboot end BEVCount=%d HaveHDBoot=%d HaveFDBoot=%d\n",
+            BEVCount, HaveHDBoot, HaveFDBoot);
 }
 
 
@@ -884,6 +930,8 @@ boot_disk(u8 bootdrv, int checksig)
     u16 bootseg = 0x07c0;
 
     // Read sector
+    printf("CSMDBG: boot_disk drv=%02x checksig=%d before int13 read\n",
+            bootdrv, checksig);
     struct bregs br;
     memset(&br, 0, sizeof(br));
     br.flags = F_IF;
@@ -893,6 +941,8 @@ boot_disk(u8 bootdrv, int checksig)
     br.al = 1;
     br.cl = 1;
     call16_int(0x13, &br);
+    printf("CSMDBG: boot_disk after int13 flags=%04x ah=%02x al=%02x\n",
+            br.flags, br.ah, br.al);
 
     if (br.flags & F_CF) {
         printf("Boot failed: could not read the boot disk\n\n");
@@ -907,6 +957,7 @@ boot_disk(u8 bootdrv, int checksig)
         }
     }
 
+    printf("CSMDBG: boot_disk MBR signature ok\n");
     tpm_add_bcv(bootdrv, MAKE_FLATPTR(bootseg, 0), 512);
 
     /* Canonicalize bootseg:bootip */
@@ -994,6 +1045,8 @@ do_boot(int seq_nr)
 
     // Boot the given BEV type.
     struct bev_s *ie = &BEV[seq_nr];
+    printf("CSMDBG: do_boot seq=%d BEVCount=%d type=%d vector=%08x\n",
+            seq_nr, BEVCount, ie->type, ie->vector);
     switch (ie->type) {
     case IPL_TYPE_FLOPPY:
         printf("Booting from Floppy...\n");
@@ -1031,6 +1084,7 @@ void VISIBLE32FLAT
 handle_18(void)
 {
     debug_enter(NULL, DEBUG_HDL_18);
+    printf("CSMDBG: int18 entry BootSequence=%d\n", BootSequence);
     int seq = BootSequence + 1;
     BootSequence = seq;
     do_boot(seq);
@@ -1041,6 +1095,7 @@ void VISIBLE32FLAT
 handle_19(void)
 {
     debug_enter(NULL, DEBUG_HDL_19);
+    printf("CSMDBG: int19 entry\n");
     BootSequence = 0;
     do_boot(0);
 }
diff --git a/src/fw/csm.c b/src/fw/csm.c
index 579debdc..ad70e9c9 100644
--- a/src/fw/csm.c
+++ b/src/fw/csm.c
@@ -9,8 +9,10 @@
 #include "e820map.h" // e820_add
 #include "farptr.h" // MAKE_FLATPTR
 #include "hw/pci.h" // pci_to_bdf
+#include "hw/pci_ids.h" // PCI_CLASS_SERIAL_USB
 #include "hw/pcidevice.h" // pci_probe_devices
 #include "hw/pic.h" // pic_irqmask_read
+#include "hw/usb.h" // struct usbdevice_s
 #include "malloc.h" // malloc_csm_preinit
 #include "memmap.h" // SYMBOL
 #include "output.h" // dprintf
@@ -19,6 +21,7 @@
 #include "std/acpi.h" // RSDP_SIGNATURE
 #include "std/bda.h" // struct bios_data_area_s
 #include "std/optionrom.h" // struct rom_header
+#include "string.h" // memset
 #include "util.h" // copy_smbios_21
 
 #define UINT8 u8
@@ -43,6 +46,19 @@ EFI_TO_COMPATIBILITY16_BOOT_TABLE *csm_boot_table;
 
 static u16 PICMask = PIC_IRQMASK_DEFAULT;
 
+#define CSM_USB_BBS_SIGNATURE 0x42535545u
+#define CSM_USB_BBS_KEY_INIT 0x811c9dc5u
+
+struct csm_usb_drive_s {
+    struct drive_s *drive;
+    struct pci_device *pci;
+    u32 key;
+    int lun;
+    struct csm_usb_drive_s *next;
+};
+
+static struct csm_usb_drive_s *CsmUsbDrives;
+
 extern void __csm_return(struct bregs *regs) __noreturn;
 
 static void
@@ -59,6 +75,73 @@ csm_return(struct bregs *regs)
     __csm_return(regs);
 }
 
+static u32
+csm_usb_bbs_key_update(u32 key, u8 data)
+{
+    key ^= data;
+    key *= 16777619;
+    return key;
+}
+
+static u32
+csm_usb_bbs_key_hub(u32 key, struct usbhub_s *hub)
+{
+    if (!hub || !hub->usbdev)
+        return key;
+
+    key = csm_usb_bbs_key_hub(key, hub->usbdev->hub);
+    key = csm_usb_bbs_key_update(key, hub->usbdev->port);
+    key = csm_usb_bbs_key_update(
+        key, hub->usbdev->iface ? hub->usbdev->iface->bInterfaceNumber : 0);
+    return key;
+}
+
+static u32
+csm_usb_bbs_key(struct usbdevice_s *usbdev, int lun)
+{
+    u32 key = csm_usb_bbs_key_hub(CSM_USB_BBS_KEY_INIT, usbdev->hub);
+    key = csm_usb_bbs_key_update(key, usbdev->port);
+    key = csm_usb_bbs_key_update(
+        key, usbdev->iface ? usbdev->iface->bInterfaceNumber : 0);
+    key = csm_usb_bbs_key_update(key, lun & 0xff);
+    return key;
+}
+
+void
+csm_register_usb_drive(struct usbdevice_s *usbdev, int lun, struct drive_s *drive)
+{
+    if (!CONFIG_CSM || !usbdev || !drive || !usbdev->hub || !usbdev->hub->cntl
+        || !usbdev->hub->cntl->pci)
+        return;
+
+    struct csm_usb_drive_s **pprev = &CsmUsbDrives;
+    for (;;) {
+        struct csm_usb_drive_s *pos = *pprev;
+        if (!pos)
+            break;
+        if (pos->drive == drive)
+            return;
+        pprev = &pos->next;
+    }
+
+    struct csm_usb_drive_s *entry = malloc_tmp(sizeof(*entry));
+    if (!entry) {
+        warn_noalloc();
+        return;
+    }
+    memset(entry, 0, sizeof(*entry));
+    entry->drive = drive;
+    entry->pci = usbdev->hub->cntl->pci;
+    entry->key = csm_usb_bbs_key(usbdev, lun);
+    entry->lun = lun;
+    *pprev = entry;
+
+    dprintf(3, "CSM registered USB drive %p on PCI %02x:%02x.%x lun %d key %08x\n",
+            drive, pci_bdf_to_bus(entry->pci->bdf),
+            pci_bdf_to_dev(entry->pci->bdf), pci_bdf_to_fn(entry->pci->bdf),
+            lun, entry->key);
+}
+
 static void
 csm_maininit(struct bregs *regs)
 {
@@ -144,6 +227,7 @@ handle_csm_0002(struct bregs *regs)
     }
 
     dprintf(3, "PrepareToBoot table %04x:%04x\n", regs->es, regs->bx);
+    csm_boot_table = MAKE_FLATPTR(regs->es, regs->bx);
 
     struct e820entry *p = (void *)csm_compat_table.E820Pointer;
     int i;
@@ -190,9 +274,14 @@ handle_csm_0002(struct bregs *regs)
     clock_setup();
     device_hardware_setup();
     wait_threads();
+    boot_update_csm_priorities();
+    printf("CSMDBG: before interactive_bootmenu\n");
     interactive_bootmenu();
+    printf("CSMDBG: after interactive_bootmenu\n");
 
+    printf("CSMDBG: before prepareboot\n");
     prepareboot();
+    printf("CSMDBG: after prepareboot\n");
 
     regs->ax = 0;
 }
@@ -207,9 +296,11 @@ handle_csm_0003(struct bregs *regs)
     }
 
     dprintf(3, "Boot\n");
+    printf("CSMDBG: Legacy16Boot entry\n");
 
     startBoot();
 
+    printf("CSMDBG: Legacy16Boot startBoot returned\n");
     regs->ax = 1;
 }
 
@@ -336,6 +427,42 @@ static int csm_prio_to_seabios(u16 csm_prio)
     }
 }
 
+int csm_bootprio_drive(struct drive_s *drive)
+{
+    if (!CONFIG_CSM || !csm_boot_table || !drive)
+        return -1;
+
+    struct csm_usb_drive_s *pos;
+    for (pos = CsmUsbDrives; pos; pos = pos->next) {
+        if (pos->drive != drive)
+            continue;
+
+        BBS_TABLE *bbs = (void *)csm_boot_table->BbsTable;
+        u16 bdf = pos->pci->bdf;
+        int i;
+
+        for (i = 5; i < csm_boot_table->NumberBbsEntries; i++) {
+            if (bdf != pci_to_bdf(bbs[i].Bus, bbs[i].Device, bbs[i].Function)
+                || bbs[i].DeviceType != BBS_HARDDISK
+                || bbs[i].Class != (PCI_CLASS_SERIAL_USB >> 8)
+                || bbs[i].SubClass != (PCI_CLASS_SERIAL_USB & 0xff))
+                continue;
+
+            if (bbs[i].IBV1 == CSM_USB_BBS_SIGNATURE
+                && bbs[i].IBV2 == pos->key) {
+                dprintf(3, "CSM bootprio for USB drive %p lun %d key %08x "
+                        "(BBS %d) is %d\n", drive, pos->lun, pos->key, i,
+                        bbs[i].BootPriority);
+                return csm_prio_to_seabios(bbs[i].BootPriority);
+            }
+        }
+
+        return -1;
+    }
+
+    return -1;
+}
+
 int csm_bootprio_ata(struct pci_device *pci, int chanid, int slave)
 {
     if (!csm_boot_table)
