     int i;
@@ -184,12 +303,10 @@ handle_csm_0002(struct bregs *regs)
     struct bios_data_area_s *bda = MAKE_FLATPTR(SEG_BDA, 0);
     bda->hdcount = 0;
 
-    thread_setup();
-    mathcp_setup();
-    timer_setup();
-    clock_setup();
+    csm_setup_basic();
     device_hardware_setup();
     wait_threads();
+    boot_update_csm_priorities();
     interactive_bootmenu();
 
     prepareboot();
@@ -336,6 +453,27 @@ static int csm_prio_to_seabios(u16 csm_prio)
     }
 }
 
+int csm_bootprio_drive(struct drive_s *drive)
+{
+    if (!CONFIG_CSM || !csm_boot_table || !drive)
+        return -1;
+
+    struct csm_usb_drive_s *pos;
+    for (pos = CsmUsbDrives; pos; pos = pos->next) {
+        if (pos->drive != drive || pos->bbs_index < 0)
+            continue;
+        if (pos->bbs_index >= csm_boot_table->NumberBbsEntries)
+            return -1;
+
+        BBS_TABLE *bbs = (void *)csm_boot_table->BbsTable;
+        dprintf(3, "CSM bootprio for USB drive %p (index %d) is %d\n",
+                drive, pos->bbs_index, bbs[pos->bbs_index].BootPriority);
+        return csm_prio_to_seabios(bbs[pos->bbs_index].BootPriority);
+    }
+
+    return -1;
+}
